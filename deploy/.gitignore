# Chrome extension signing artifacts (local only)
chrome-extension.pem
chrome-extension.crx

# Environment configuration (contains sensitive information)
.env

# Backup files
*.backup
*.bak

# Temporary files
*.tmp
*.log

# Local script dependencies (level/cherry tooling)
scripts/node_modules/
