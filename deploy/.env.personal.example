# 在已有 deploy/.env 基础上追加以下项（setup-personal.ps1 会自动合并）

SERVER_PORT=5870
KHOJ_PORT=5871
RUN_MODE=simple

CHERRY_STUDIO_INSTALL_PATH=E:\cherry-studio\Cherry Studio
SUB2API_API_KEY=
SUB2API_REMOTE_URL=https://api.coolapihub.khtain.com/v1/
# coolapihub 管理员（仅本地驾驶舱 / 勿提交 Git）
SUB2API_COCKPIT_EMAIL=your_admin@email.com
SUB2API_COCKPIT_PASSWORD=change_me

KHOJ_ADMIN_EMAIL=brain@localhost
KHOJ_ADMIN_PASSWORD=change_me
KHOJ_POSTGRES_USER=postgres
KHOJ_POSTGRES_PASSWORD=change_me
KHOJ_POSTGRES_DB=postgres
KHOJ_DJANGO_SECRET_KEY=
