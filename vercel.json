{
  "buildCommand": "cd frontend && npm install --legacy-peer-deps && npx vite build",
  "outputDirectory": "backend/internal/web/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.coolapihub.khtain.com/api/$1"
    },
    {
      "source": "/v1/(.*)",
      "destination": "https://api.coolapihub.khtain.com/v1/$1"
    },
    {
      "source": "/setup/(.*)",
      "destination": "https://api.coolapihub.khtain.com/setup/$1"
    },
    {
      "source": "/health",
      "destination": "https://api.coolapihub.khtain.com/health"
    },
    {
      "source": "/((?!assets/|logo.png|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
